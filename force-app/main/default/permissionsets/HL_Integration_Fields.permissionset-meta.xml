<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>HL Integration Fields</label>
    <description>Grants read/edit on the Higher Logic integration ID fields so admins can view and maintain them. The integration itself runs in system mode and does not need this.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.HL_Community_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Contact.HL_Contact_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Campaign.HL_Event_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Campaign.HL_Event_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
